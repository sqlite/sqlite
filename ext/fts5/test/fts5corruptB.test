source [file join [file dirname [info script]] fts5_common.tcl]
set testprefix fts5corruptB

# If SQLITE_ENABLE_FTS5 is not defined, omit this file.
ifcapable !fts5 {
  finish_test
  return
}
sqlite3_fts5_may_be_corrupt 1

